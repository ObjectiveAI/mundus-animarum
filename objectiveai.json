{
  "owner": "ObjectiveAI",
  "name": "mundus-animarum",
  "version": "0.1.0",
  "description": "Soul storage for ObjectiveAI agents — a persistent, self-authored key/value store per agent, with cross-agent subscriptions and change notifications, exposed over MCP.",
  "exec": {
    "windows": ["./mundus-animarum.exe"],
    "linux": ["./mundus-animarum"],
    "macos": ["./mundus-animarum"]
  },
  "cli_zip": {
    "windows": { "x86_64": "mundus-animarum-windows-x86_64.zip", "aarch64": "mundus-animarum-windows-aarch64.zip" },
    "linux": { "x86_64": "mundus-animarum-linux-x86_64.zip", "aarch64": "mundus-animarum-linux-aarch64.zip" },
    "macos": { "x86_64": "mundus-animarum-macos-x86_64.zip", "aarch64": "mundus-animarum-macos-aarch64.zip" }
  },
  "mcp_servers": [
    { "name": "mundus-animarum", "authorization": false }
  ]
}
